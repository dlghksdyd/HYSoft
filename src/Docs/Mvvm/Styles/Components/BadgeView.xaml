<UserControl
    x:Class="Docs.Mvvm.Styles.Components.BadgeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyBadge in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyBadge " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="Text=&quot;New&quot; BadgeType=&quot;Info&quot;" />
                            <Run Text=" /&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- All Badge Types -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="All Badge Types" />
                <WrapPanel Margin="0,0,0,16" Orientation="Horizontal">
                    <hy:HyBadge Text="Neutral" BadgeType="Neutral" Margin="0,0,8,8" />
                    <hy:HyBadge Text="Info" BadgeType="Info" Margin="0,0,8,8" />
                    <hy:HyBadge Text="Success" BadgeType="Success" Margin="0,0,8,8" />
                    <hy:HyBadge Text="Warning" BadgeType="Warning" Margin="0,0,8,8" />
                    <hy:HyBadge Text="Error" BadgeType="Error" Margin="0,0,8,8" />
                    <hy:HyBadge Text="Highlight" BadgeType="Highlight" Margin="0,0,8,8" />
                </WrapPanel>

                <!-- CornerRadius -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="CornerRadius" />
                <WrapPanel Margin="0,0,0,16" Orientation="Horizontal">
                    <hy:HyBadge Text="Radius 0" BadgeType="Info" CornerRadius="0" Margin="0,0,8,8" />
                    <hy:HyBadge Text="Radius 4" BadgeType="Info" CornerRadius="4" Margin="0,0,8,8" />
                    <hy:HyBadge Text="Radius 8 (default)" BadgeType="Info" CornerRadius="8" Margin="0,0,8,8" />
                    <hy:HyBadge Text="Radius 16" BadgeType="Info" CornerRadius="16" Margin="0,0,8,8" />
                </WrapPanel>

                <!-- Usage with context -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Badges in Context" />
                <StackPanel Margin="0,0,0,16" Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Build Status: " VerticalAlignment="Center" Margin="0,0,8,0" />
                        <hy:HyBadge Text="Passing" BadgeType="Success" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Version: " VerticalAlignment="Center" Margin="0,0,8,0" />
                        <hy:HyBadge Text="v1.0.0" BadgeType="Highlight" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Deprecation: " VerticalAlignment="Center" Margin="0,0,8,0" />
                        <hy:HyBadge Text="Deprecated" BadgeType="Warning" />
                    </StackPanel>
                </StackPanel>

                <!-- 3. Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="Text" /><Run Text=" (string) - The text displayed in the badge" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="BadgeType" /><Run Text=" (EBadgeType) - Badge style type. Values: Neutral, Info, Success, Warning, Error, Highlight" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="CornerRadius" /><Run Text=" (CornerRadius) - Border corner radius. Default: 8" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
