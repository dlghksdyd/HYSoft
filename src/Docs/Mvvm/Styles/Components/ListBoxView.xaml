<UserControl
    x:Class="Docs.Mvvm.Styles.Components.ListBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}"
                    Text="- Use HyListBox with HyListBoxItem in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="&lt;hy:HyListBox&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;hy:HyListBoxItem Content=&quot;Item 1&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;hy:HyListBoxItem Content=&quot;Item 2&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;hy:HyListBoxItem Content=&quot;Item 3&quot; /&gt;" />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="&lt;/hy:HyListBox&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- Default -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Default" />
                <hy:HyListBox Width="300" HorizontalAlignment="Left" Margin="0,0,0,16">
                    <hy:HyListBoxItem Content="Apple" />
                    <hy:HyListBoxItem Content="Banana" />
                    <hy:HyListBoxItem Content="Cherry" />
                    <hy:HyListBoxItem Content="Date" />
                    <hy:HyListBoxItem Content="Elderberry" />
                </hy:HyListBox>

                <!-- CornerRadius -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="CornerRadius" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <hy:HyListBox Width="200" CornerRadius="0" Margin="0,0,8,0">
                        <hy:HyListBoxItem Content="Radius 0" CornerRadius="0" />
                        <hy:HyListBoxItem Content="Sharp corners" CornerRadius="0" />
                    </hy:HyListBox>
                    <hy:HyListBox Width="200" CornerRadius="8">
                        <hy:HyListBoxItem Content="Radius 8" CornerRadius="8" />
                        <hy:HyListBoxItem Content="Rounded corners" CornerRadius="8" />
                    </hy:HyListBox>
                </StackPanel>

                <!-- Disabled -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Disabled" />
                <hy:HyListBox Width="300" HorizontalAlignment="Left" Margin="0,0,0,16" IsEnabled="False">
                    <hy:HyListBoxItem Content="Disabled Item 1" />
                    <hy:HyListBoxItem Content="Disabled Item 2" />
                </hy:HyListBox>

                <!-- 3. Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="HyListBox" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  CornerRadius" /><Run Text=" (CornerRadius) - ListBox border corner radius" /></Paragraph>
                        <Paragraph />
                        <Paragraph><Run FontWeight="Bold" Text="HyListBoxItem" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  CornerRadius" /><Run Text=" (CornerRadius) - ListBoxItem corner radius" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
