<UserControl
    x:Class="Docs.Mvvm.Styles.Components.ExpanderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyExpander / HyGroupBox in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyExpander Header=&quot;Section&quot; " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="CornerRadius=&quot;4&quot;" />
                            <Run Text="&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;TextBlock Text=&quot;Content&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="&lt;/hy:HyExpander&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Live Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- Expanded -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="HyExpander (Expanded)" />
                <hy:HyExpander Header="Expanded Section" IsExpanded="True" Margin="0,0,0,16">
                    <StackPanel Margin="8">
                        <TextBlock Text="This is the content inside the expander." Foreground="{hy:Color TextPrimary}" />
                        <TextBlock Text="It can contain any elements." Foreground="{hy:Color TextPrimary}" Margin="0,4,0,0" />
                    </StackPanel>
                </hy:HyExpander>

                <!-- Collapsed -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="HyExpander (Collapsed)" />
                <hy:HyExpander Header="Collapsed Section" IsExpanded="False" Margin="0,0,0,16">
                    <TextBlock Text="This content is hidden when collapsed." Margin="8" Foreground="{hy:Color TextPrimary}" />
                </hy:HyExpander>

                <!-- CornerRadius -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="HyExpander CornerRadius" />
                <hy:HyExpander Header="Rounded Expander" CornerRadius="8" IsExpanded="True" Margin="0,0,0,16">
                    <TextBlock Text="Expander with CornerRadius=8" Margin="8" Foreground="{hy:Color TextPrimary}" />
                </hy:HyExpander>

                <!-- HyGroupBox -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="HyGroupBox" />
                <hy:HyGroupBox Header="Group Box Section" CornerRadius="4" Margin="0,0,0,16">
                    <StackPanel Margin="8">
                        <TextBlock Text="GroupBox content area." Foreground="{hy:Color TextPrimary}" />
                        <TextBlock Text="Use HyGroupBox to group related controls." Foreground="{hy:Color TextPrimary}" Margin="0,4,0,0" />
                    </StackPanel>
                </hy:HyGroupBox>

                <!-- HyGroupBox CornerRadius -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="HyGroupBox CornerRadius" />
                <hy:HyGroupBox Header="Rounded GroupBox" CornerRadius="8" Margin="0,0,0,16">
                    <TextBlock Text="GroupBox with CornerRadius=8" Margin="8" Foreground="{hy:Color TextPrimary}" />
                </hy:HyGroupBox>

                <!-- 3. Custom Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Custom Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="HyExpander.CornerRadius" /><Run Text=" (CornerRadius) - Expander border corner radius. Default: 4" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="HyGroupBox.CornerRadius" /><Run Text=" (CornerRadius) - GroupBox border corner radius. Default: 4" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 4. Base Properties (inherited) -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="4. Base Properties (inherited)" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="HyExpander" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Background" /><Run Text=" (Brush) - Control background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Foreground" /><Run Text=" (Brush) - Text color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  FontSize" /><Run Text=" (double) - Font size" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  FontWeight" /><Run Text=" (FontWeight) - Font weight" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Padding" /><Run Text=" (Thickness) - Inner padding" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Margin" /><Run Text=" (Thickness) - Outer margin" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Width" /><Run Text=" (double) - Control width" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Height" /><Run Text=" (double) - Control height" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  HorizontalAlignment" /><Run Text=" (HorizontalAlignment) - Horizontal alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  VerticalAlignment" /><Run Text=" (VerticalAlignment) - Vertical alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  IsEnabled" /><Run Text=" (bool) - Whether the control is enabled" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Visibility" /><Run Text=" (Visibility) - Control visibility" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Opacity" /><Run Text=" (double) - Control opacity (0.0 to 1.0)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Cursor" /><Run Text=" (Cursor) - Mouse cursor when hovering" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  ToolTip" /><Run Text=" (object) - Tooltip content" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Header" /><Run Text=" (object) - Expander header content" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  IsExpanded" /><Run Text=" (bool) - Whether the expander is expanded" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  ExpandDirection" /><Run Text=" (ExpandDirection) - Direction of expansion (Down, Up, Left, Right)" /></Paragraph>
                        <Paragraph />
                        <Paragraph><Run FontWeight="Bold" Text="HyGroupBox" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Background" /><Run Text=" (Brush) - Control background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Foreground" /><Run Text=" (Brush) - Text color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  FontSize" /><Run Text=" (double) - Font size" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  FontWeight" /><Run Text=" (FontWeight) - Font weight" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Padding" /><Run Text=" (Thickness) - Inner padding" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Margin" /><Run Text=" (Thickness) - Outer margin" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Width" /><Run Text=" (double) - Control width" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Height" /><Run Text=" (double) - Control height" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  HorizontalAlignment" /><Run Text=" (HorizontalAlignment) - Horizontal alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  VerticalAlignment" /><Run Text=" (VerticalAlignment) - Vertical alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  IsEnabled" /><Run Text=" (bool) - Whether the control is enabled" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Visibility" /><Run Text=" (Visibility) - Control visibility" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Opacity" /><Run Text=" (double) - Control opacity (0.0 to 1.0)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Cursor" /><Run Text=" (Cursor) - Mouse cursor when hovering" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  ToolTip" /><Run Text=" (object) - Tooltip content" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Header" /><Run Text=" (object) - GroupBox header content" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  Content" /><Run Text=" (object) - GroupBox content" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
