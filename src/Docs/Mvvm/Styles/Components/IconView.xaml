<UserControl
    x:Class="Docs.Mvvm.Styles.Components.IconView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:IconViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="900"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="1. Getting Started" />
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{hy:FontSize Md}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="- Include xmlns:hy=&quot;http://schemas.hysoft.com/wpf/2025/xaml&quot; in your XAML file." />
                <RichTextBox
                    Margin="0,0,0,8"
                    Padding="8"
                    FontSize="{hy:FontSize Sm}">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;UserControl&gt;" />
                            <LineBreak />
                            <Run Text="    x:Class=&quot;Docs.Mvvm.UiSupport.Icons.GettingStartedView&quot;" />
                            <LineBreak />
                            <Run Text="    xmlns=&quot;http://schemas.microsoft.com/winfx/2006/xaml/presentation&quot;" />
                            <LineBreak />
                            <Run Text="    xmlns:x=&quot;http://schemas.microsoft.com/winfx/2006/xaml&quot;" />
                            <LineBreak />
                            <Run Text="    xmlns:d=&quot;http://schemas.microsoft.com/expression/blend/2008&quot;" />
                            <LineBreak />

                            <!--  강조  -->
                            <Run
                                FontWeight="Bold"
                                Foreground="{hy:Color TextError}"
                                Text="    xmlns:hy=&quot;http://schemas.hysoft.com/wpf/2025/xaml&quot;" />

                            <LineBreak />
                            <Run Text="    xmlns:local=&quot;clr-namespace:Docs.Mvvm.UiSupport.Icons&quot;" />
                            <LineBreak />
                            <Run Text="    xmlns:mc=&quot;http://schemas.openxmlformats.org/markup-compatibility/2006&quot;" />
                            <LineBreak />
                            <Run Text="    mc:Ignorable=&quot;d&quot;&gt;" />
                            <LineBreak />
                            <Run Text="&lt;/UserControl&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{hy:FontSize Md}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="- Use HyIcon Component in XAML" />
                <RichTextBox
                    Margin="0,0,0,16"
                    Padding="8"
                    FontSize="{hy:FontSize Sm}">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyIcon Source=&quot;" />
                            <Run
                                FontStyle="Italic"
                                Foreground="{hy:Color TextError}"
                                Text="[icon_asset_key]" />
                            <Run Text="&quot; Color=&quot;Black&quot; ColorHover=&quot;Blue&quot;" />
                            <Run Text=" ColorPressed=&quot;Aquamarine&quot;/&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="2. Icon Assets" />
                <Border Grid.Row="0">
                    <hy:HyTextBox
                        Width="250"
                        Height="32"
                        HorizontalAlignment="Left"
                        BorderBrush="{hy:Color BorderDefault}"
                        BorderThickness="1"
                        Watermark="Search Icon Asset Key"
                        WatermarkForeground="{hy:Color TextWatermark}">
                        <hy:EventToCommand.Binding>
                            <hy:Event Command="{Binding SearchTextChanged, UpdateSourceTrigger=PropertyChanged}" RoutedEvent="TextBox.TextChanged" />
                        </hy:EventToCommand.Binding>
                    </hy:HyTextBox>
                </Border>
                <ItemsControl ItemsSource="{Binding Keys}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <hy:HyIcon
                                    Grid.Row="0"
                                    Width="32"
                                    Height="32"
                                    Source="{Binding}" />
                                <TextBlock
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    Text="{Binding}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 3. Custom Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Custom Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="Source" /><Run Text=" (string) - Icon asset key name" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Color" /><Run Text=" (Brush) - Icon color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ColorHover" /><Run Text=" (Brush) - Icon color on mouse hover" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ColorPressed" /><Run Text=" (Brush) - Icon color when pressed" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsPressed" /><Run Text=" (bool) - Whether the icon is in pressed state" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="CornerRadius" /><Run Text=" (CornerRadius) - Border corner radius" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 4. Base Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="4. Base Properties (inherited)" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="Background" /><Run Text=" (Brush) - Control background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Foreground" /><Run Text=" (Brush) - Text/content color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontSize" /><Run Text=" (double) - Font size of content text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontWeight" /><Run Text=" (FontWeight) - Font weight of content text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Padding" /><Run Text=" (Thickness) - Inner spacing between border and content" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Margin" /><Run Text=" (Thickness) - Outer spacing around the control" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Width" /><Run Text=" (double) - Control width" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Height" /><Run Text=" (double) - Control height" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="HorizontalAlignment" /><Run Text=" (HorizontalAlignment) - Horizontal alignment within parent" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="VerticalAlignment" /><Run Text=" (VerticalAlignment) - Vertical alignment within parent" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsEnabled" /><Run Text=" (bool) - Whether the control is interactive" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Visibility" /><Run Text=" (Visibility) - Control visibility (Visible, Hidden, Collapsed)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Opacity" /><Run Text=" (double) - Control opacity (0.0 to 1.0)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Cursor" /><Run Text=" (Cursor) - Mouse cursor when hovering" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ToolTip" /><Run Text=" (object) - Tooltip shown on hover" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
