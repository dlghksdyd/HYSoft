<UserControl
    x:Class="Docs.Mvvm.Styles.Components.ButtonView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="900"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="1. Getting Started" />
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{hy:FontSize Md}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="- Use HyButton in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyButton Content=&quot;Click Me&quot; " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="CornerRadius=&quot;8&quot;" />
                            <Run Text=" /&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Live Examples -->
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="2. Examples" />

                <!-- Default -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Default" />
                <hy:HyButton Margin="0,0,0,16" Content="Default Button" HorizontalAlignment="Left" Padding="16,8" />

                <!-- CornerRadius -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="CornerRadius" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <hy:HyButton Content="Radius 0" CornerRadius="0" Padding="16,8" Margin="0,0,8,0" />
                    <hy:HyButton Content="Radius 4" CornerRadius="4" Padding="16,8" Margin="0,0,8,0" />
                    <hy:HyButton Content="Radius 8" CornerRadius="8" Padding="16,8" Margin="0,0,8,0" />
                    <hy:HyButton Content="Radius 16" CornerRadius="16" Padding="16,8" />
                </StackPanel>

                <!-- With Icon -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="With Icon" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <hy:HyButton Padding="8" Margin="0,0,8,0" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <hy:HyIcon Source="Save" Width="16" Height="16" Color="Black" Margin="0,0,6,0" />
                            <TextBlock Text="Save" VerticalAlignment="Center" />
                        </StackPanel>
                    </hy:HyButton>
                    <hy:HyButton Padding="8" Margin="0,0,8,0" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <hy:HyIcon Source="Delete" Width="16" Height="16" Color="Black" Margin="0,0,6,0" />
                            <TextBlock Text="Delete" VerticalAlignment="Center" />
                        </StackPanel>
                    </hy:HyButton>
                </StackPanel>

                <!-- Disabled -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Disabled" />
                <hy:HyButton Margin="0,0,0,16" Content="Disabled Button" IsEnabled="False" HorizontalAlignment="Left" Padding="16,8" />

                <!-- 3. Custom Properties -->
                <TextBlock
                    Margin="0,16,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="3. Custom Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="CornerRadius" />
                            <Run Text=" (CornerRadius) - Border corner radius. Default: 0" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 4. Base Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="4. Base Properties (inherited)" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="Content" /><Run Text=" (object) - Button content (text, UI elements, etc.)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsPressed" /><Run Text=" (bool) - Whether the button is currently pressed" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Command" /><Run Text=" (ICommand) - Command to execute on click" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="CommandParameter" /><Run Text=" (object) - Parameter passed to Command" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ClickMode" /><Run Text=" (ClickMode) - When the Click event fires (Release, Press, Hover)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Background" /><Run Text=" (Brush) - Control background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Foreground" /><Run Text=" (Brush) - Text/content color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontSize" /><Run Text=" (double) - Font size of content text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontWeight" /><Run Text=" (FontWeight) - Font weight of content text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Padding" /><Run Text=" (Thickness) - Inner spacing between border and content" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Margin" /><Run Text=" (Thickness) - Outer spacing around the control" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Width" /><Run Text=" (double) - Control width" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Height" /><Run Text=" (double) - Control height" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="HorizontalAlignment" /><Run Text=" (HorizontalAlignment) - Horizontal alignment within parent" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="VerticalAlignment" /><Run Text=" (VerticalAlignment) - Vertical alignment within parent" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsEnabled" /><Run Text=" (bool) - Whether the control is interactive" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Visibility" /><Run Text=" (Visibility) - Control visibility (Visible, Hidden, Collapsed)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Opacity" /><Run Text=" (double) - Control opacity (0.0 to 1.0)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Cursor" /><Run Text=" (Cursor) - Mouse cursor when hovering" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ToolTip" /><Run Text=" (object) - Tooltip shown on hover" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
