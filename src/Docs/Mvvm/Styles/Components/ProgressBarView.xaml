<UserControl
    x:Class="Docs.Mvvm.Styles.Components.ProgressBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyProgressBar in XAML" />
                <RichTextBox Margin="0,0,0,8" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyProgressBar " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="Value=&quot;50&quot; Maximum=&quot;100&quot;" />
                            <Run Text=" /&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyProgressRing in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyProgressRing " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="IsActive=&quot;True&quot;" />
                            <Run Text=" /&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- ProgressBar at various percentages -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="ProgressBar - Various Percentages" />
                <StackPanel Margin="0,0,0,16" Orientation="Vertical">
                    <TextBlock Margin="0,0,0,4" Text="0%" />
                    <hy:HyProgressBar Margin="0,0,0,8" Value="0" Maximum="100" />
                    <TextBlock Margin="0,0,0,4" Text="50%" />
                    <hy:HyProgressBar Margin="0,0,0,8" Value="50" Maximum="100" />
                    <TextBlock Margin="0,0,0,4" Text="100%" />
                    <hy:HyProgressBar Margin="0,0,0,8" Value="100" Maximum="100" />
                </StackPanel>

                <!-- Indeterminate -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="ProgressBar - Indeterminate" />
                <hy:HyProgressBar Margin="0,0,0,16" IsIndeterminate="True" />

                <!-- CornerRadius -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="ProgressBar - CornerRadius" />
                <StackPanel Margin="0,0,0,16" Orientation="Vertical">
                    <hy:HyProgressBar Margin="0,0,0,8" Value="60" Maximum="100" CornerRadius="0" />
                    <hy:HyProgressBar Margin="0,0,0,8" Value="60" Maximum="100" CornerRadius="4" />
                    <hy:HyProgressBar Margin="0,0,0,8" Value="60" Maximum="100" CornerRadius="8" />
                </StackPanel>

                <!-- ProgressRing -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="ProgressRing - Spinning" />
                <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                    <hy:HyProgressRing IsActive="True" RingSize="24" Margin="0,0,16,0" />
                    <hy:HyProgressRing IsActive="True" RingSize="32" Margin="0,0,16,0" />
                    <hy:HyProgressRing IsActive="True" RingSize="48" />
                </StackPanel>

                <!-- 3. Custom Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Custom Properties" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="HyProgressBar" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="CornerRadius" /><Run Text=" (CornerRadius) - Border corner radius. Default: 4" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="TrackBackground" /><Run Text=" (Brush) - Background color of the track" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="HyProgressRing" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="IsActive" /><Run Text=" (bool) - Whether the ring is spinning. Default: true" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="RingSize" /><Run Text=" (double) - Diameter of the ring. Default: 32" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="StrokeThickness" /><Run Text=" (double) - Ring stroke width. Default: 3" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="RingColor" /><Run Text=" (Brush) - Color of the ring" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 4. Base Properties (inherited) -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="4. Base Properties (inherited)" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="Background" /><Run Text=" (Brush) - Control background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Foreground" /><Run Text=" (Brush) - Text color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontSize" /><Run Text=" (double) - Font size" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontWeight" /><Run Text=" (FontWeight) - Font weight" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Padding" /><Run Text=" (Thickness) - Inner padding" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Margin" /><Run Text=" (Thickness) - Outer margin" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Width" /><Run Text=" (double) - Control width" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Height" /><Run Text=" (double) - Control height" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="HorizontalAlignment" /><Run Text=" (HorizontalAlignment) - Horizontal alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="VerticalAlignment" /><Run Text=" (VerticalAlignment) - Vertical alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsEnabled" /><Run Text=" (bool) - Whether the control is enabled" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Visibility" /><Run Text=" (Visibility) - Control visibility" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Opacity" /><Run Text=" (double) - Control opacity (0.0 to 1.0)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Cursor" /><Run Text=" (Cursor) - Mouse cursor when hovering" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ToolTip" /><Run Text=" (object) - Tooltip content" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Value" /><Run Text=" (double) - Current progress value" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Minimum" /><Run Text=" (double) - Minimum value" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Maximum" /><Run Text=" (double) - Maximum value" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsIndeterminate" /><Run Text=" (bool) - Whether to show indeterminate animation" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Orientation" /><Run Text=" (Orientation) - Horizontal or Vertical" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
