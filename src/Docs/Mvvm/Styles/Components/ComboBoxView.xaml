<UserControl
    x:Class="Docs.Mvvm.Styles.Components.ComboBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyComboBox in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyComboBox " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="CornerRadius=&quot;4&quot; PopupCornerRadius=&quot;4&quot;" />
                            <Run Text="&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;ComboBoxItem Content=&quot;Item 1&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;ComboBoxItem Content=&quot;Item 2&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="&lt;/hy:HyComboBox&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- Default -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Default" />
                <hy:HyComboBox Width="200" HorizontalAlignment="Left" Margin="0,0,0,16" SelectedIndex="0">
                    <ComboBoxItem Content="Apple" />
                    <ComboBoxItem Content="Banana" />
                    <ComboBoxItem Content="Cherry" />
                </hy:HyComboBox>

                <!-- CornerRadius -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="CornerRadius" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <hy:HyComboBox Width="150" CornerRadius="0" SelectedIndex="0" Margin="0,0,8,0">
                        <ComboBoxItem Content="Radius 0" />
                    </hy:HyComboBox>
                    <hy:HyComboBox Width="150" CornerRadius="8" SelectedIndex="0" Margin="0,0,8,0">
                        <ComboBoxItem Content="Radius 8" />
                    </hy:HyComboBox>
                </StackPanel>

                <!-- Disabled -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Disabled" />
                <hy:HyComboBox Width="200" HorizontalAlignment="Left" Margin="0,0,0,16" IsEnabled="False" SelectedIndex="0">
                    <ComboBoxItem Content="Disabled" />
                </hy:HyComboBox>

                <!-- 3. Custom Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Custom Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="CornerRadius" /><Run Text=" (CornerRadius) - ComboBox border radius" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="PopupCornerRadius" /><Run Text=" (CornerRadius) - Dropdown popup radius" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="PopupBorderThickness" /><Run Text=" (Thickness) - Popup border width. Default: 1" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="PopupHorizontalOffset" /><Run Text=" (double) - Popup X offset. Default: 0" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="PopupVerticalOffset" /><Run Text=" (double) - Popup Y offset. Default: 0" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 4. Base Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="4. Base Properties (inherited)" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="ItemsSource" /><Run Text=" (IEnumerable) - Data source for items" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SelectedItem" /><Run Text=" (object) - Currently selected item" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SelectedIndex" /><Run Text=" (int) - Index of the selected item" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SelectedValue" /><Run Text=" (object) - Value of the selected item" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="DisplayMemberPath" /><Run Text=" (string) - Property path for display text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsEditable" /><Run Text=" (bool) - Whether the ComboBox text area is editable" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsDropDownOpen" /><Run Text=" (bool) - Whether the dropdown is open" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Background" /><Run Text=" (Brush) - Control background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Foreground" /><Run Text=" (Brush) - Text/content color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontSize" /><Run Text=" (double) - Font size of content text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontWeight" /><Run Text=" (FontWeight) - Font weight of content text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Padding" /><Run Text=" (Thickness) - Inner spacing between border and content" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Margin" /><Run Text=" (Thickness) - Outer spacing around the control" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Width" /><Run Text=" (double) - Control width" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Height" /><Run Text=" (double) - Control height" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="HorizontalAlignment" /><Run Text=" (HorizontalAlignment) - Horizontal alignment within parent" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="VerticalAlignment" /><Run Text=" (VerticalAlignment) - Vertical alignment within parent" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsEnabled" /><Run Text=" (bool) - Whether the control is interactive" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Visibility" /><Run Text=" (Visibility) - Control visibility (Visible, Hidden, Collapsed)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Opacity" /><Run Text=" (double) - Control opacity (0.0 to 1.0)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Cursor" /><Run Text=" (Cursor) - Mouse cursor when hovering" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ToolTip" /><Run Text=" (object) - Tooltip shown on hover" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
