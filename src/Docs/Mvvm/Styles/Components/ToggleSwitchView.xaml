<UserControl
    x:Class="Docs.Mvvm.Styles.Components.ToggleSwitchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyToggleSwitch in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyToggleSwitch " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="IsChecked=&quot;True&quot;" />
                            <Run Text=" /&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Live Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- Default -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Default" />
                <StackPanel Margin="0,0,0,16" Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <hy:HyToggleSwitch Margin="0,0,8,0" />
                        <TextBlock Text="Off" VerticalAlignment="Center" Foreground="{hy:Color TextPrimary}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <hy:HyToggleSwitch IsChecked="True" Margin="0,0,8,0" />
                        <TextBlock Text="On" VerticalAlignment="Center" Foreground="{hy:Color TextPrimary}" />
                    </StackPanel>
                </StackPanel>

                <!-- Custom Size -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Custom Size" />
                <StackPanel Margin="0,0,0,16" Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <hy:HyToggleSwitch SwitchWidth="36" SwitchHeight="18" ThumbSize="12" IsChecked="True" Margin="0,0,8,0" />
                        <TextBlock Text="Small (36x18, Thumb=12)" VerticalAlignment="Center" Foreground="{hy:Color TextPrimary}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <hy:HyToggleSwitch SwitchWidth="44" SwitchHeight="22" ThumbSize="16" IsChecked="True" Margin="0,0,8,0" />
                        <TextBlock Text="Default (44x22, Thumb=16)" VerticalAlignment="Center" Foreground="{hy:Color TextPrimary}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <hy:HyToggleSwitch SwitchWidth="56" SwitchHeight="28" ThumbSize="22" IsChecked="True" Margin="0,0,8,0" />
                        <TextBlock Text="Large (56x28, Thumb=22)" VerticalAlignment="Center" Foreground="{hy:Color TextPrimary}" />
                    </StackPanel>
                </StackPanel>

                <!-- Custom Colors -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Custom Colors" />
                <StackPanel Margin="0,0,0,16" Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <hy:HyToggleSwitch IsChecked="True" OnBackground="Green" Margin="0,0,8,0" />
                        <TextBlock Text="OnBackground=Green" VerticalAlignment="Center" Foreground="{hy:Color TextPrimary}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <hy:HyToggleSwitch IsChecked="False" OffBackground="DarkGray" Margin="0,0,8,0" />
                        <TextBlock Text="OffBackground=DarkGray" VerticalAlignment="Center" Foreground="{hy:Color TextPrimary}" />
                    </StackPanel>
                </StackPanel>

                <!-- Disabled -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Disabled" />
                <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                    <hy:HyToggleSwitch IsEnabled="False" Margin="0,0,8,0" />
                    <hy:HyToggleSwitch IsChecked="True" IsEnabled="False" />
                </StackPanel>

                <!-- 3. Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="SwitchWidth" /><Run Text=" (double) - Total width of the switch track. Default: 44" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SwitchHeight" /><Run Text=" (double) - Total height of the switch track. Default: 22" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ThumbSize" /><Run Text=" (double) - Diameter of the toggle thumb. Default: 16" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="OnBackground" /><Run Text=" (Brush) - Track background when checked (on)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="OffBackground" /><Run Text=" (Brush) - Track background when unchecked (off)" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
