<UserControl
    x:Class="Docs.Mvvm.Styles.Components.TabControlView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}"
                    Text="- Use HyTabControl with HyTabItem in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="&lt;hy:HyTabControl&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;hy:HyTabItem Header=&quot;Tab 1&quot;&gt;" />
                            <LineBreak />
                            <Run Text="        &lt;TextBlock Text=&quot;Content 1&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;/hy:HyTabItem&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;hy:HyTabItem Header=&quot;Tab 2&quot;&gt;" />
                            <LineBreak />
                            <Run Text="        &lt;TextBlock Text=&quot;Content 2&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;/hy:HyTabItem&gt;" />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="&lt;/hy:HyTabControl&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- Default -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Default" />
                <hy:HyTabControl Height="200" Margin="0,0,0,16">
                    <hy:HyTabItem Header="General">
                        <StackPanel Margin="12">
                            <TextBlock Text="General settings content" />
                            <TextBlock Margin="0,8,0,0" Text="Configure your preferences here." />
                        </StackPanel>
                    </hy:HyTabItem>
                    <hy:HyTabItem Header="Appearance">
                        <StackPanel Margin="12">
                            <TextBlock Text="Appearance settings content" />
                            <TextBlock Margin="0,8,0,0" Text="Customize the look and feel." />
                        </StackPanel>
                    </hy:HyTabItem>
                    <hy:HyTabItem Header="Advanced">
                        <StackPanel Margin="12">
                            <TextBlock Text="Advanced settings content" />
                            <TextBlock Margin="0,8,0,0" Text="For power users only." />
                        </StackPanel>
                    </hy:HyTabItem>
                </hy:HyTabControl>

                <!-- CornerRadius -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="CornerRadius" />
                <hy:HyTabControl Height="150" CornerRadius="8" Margin="0,0,0,16">
                    <hy:HyTabItem Header="Rounded" CornerRadius="8">
                        <TextBlock Margin="12" Text="TabControl and TabItem with CornerRadius=8" />
                    </hy:HyTabItem>
                    <hy:HyTabItem Header="Tab 2" CornerRadius="8">
                        <TextBlock Margin="12" Text="Second tab content" />
                    </hy:HyTabItem>
                </hy:HyTabControl>

                <!-- Disabled Tab -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Disabled Tab" />
                <hy:HyTabControl Height="150" Margin="0,0,0,16">
                    <hy:HyTabItem Header="Enabled">
                        <TextBlock Margin="12" Text="This tab is enabled" />
                    </hy:HyTabItem>
                    <hy:HyTabItem Header="Disabled" IsEnabled="False">
                        <TextBlock Margin="12" Text="This tab is disabled" />
                    </hy:HyTabItem>
                </hy:HyTabControl>

                <!-- 3. Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="HyTabControl" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  CornerRadius" /><Run Text=" (CornerRadius) - TabControl border corner radius" /></Paragraph>
                        <Paragraph />
                        <Paragraph><Run FontWeight="Bold" Text="HyTabItem" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="  CornerRadius" /><Run Text=" (CornerRadius) - TabItem header corner radius" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
