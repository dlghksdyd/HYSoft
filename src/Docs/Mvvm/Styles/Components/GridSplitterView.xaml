<UserControl
    x:Class="Docs.Mvvm.Styles.Components.GridSplitterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyGridSplitter in a Grid to create resizable panels" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;Grid&gt;" />
                            <LineBreak />
                            <Run Text="  &lt;Grid.ColumnDefinitions&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;ColumnDefinition Width=&quot;*&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;ColumnDefinition Width=&quot;Auto&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;ColumnDefinition Width=&quot;*&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="  &lt;/Grid.ColumnDefinitions&gt;" />
                            <LineBreak />
                            <Run Text="  &lt;TextBlock Grid.Column=&quot;0&quot; Text=&quot;Left&quot; /&gt;" />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="  &lt;hy:HyGridSplitter Grid.Column=&quot;1&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="  &lt;TextBlock Grid.Column=&quot;2&quot; Text=&quot;Right&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="&lt;/Grid&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- Default -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Horizontal Split (Two Columns)" />
                <Border Margin="0,0,0,16" BorderBrush="{hy:Color BorderDefault}" BorderThickness="1" Height="200">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Padding="12">
                            <TextBlock Text="Left Panel" Foreground="{hy:Color TextPrimary}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <hy:HyGridSplitter Grid.Column="1" />
                        <Border Grid.Column="2" Padding="12">
                            <TextBlock Text="Right Panel" Foreground="{hy:Color TextPrimary}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Custom thickness -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Custom SplitterThickness" />
                <Border Margin="0,0,0,16" BorderBrush="{hy:Color BorderDefault}" BorderThickness="1" Height="200">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Padding="12">
                            <TextBlock Text="Left Panel" Foreground="{hy:Color TextPrimary}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <hy:HyGridSplitter Grid.Column="1" SplitterThickness="8" />
                        <Border Grid.Column="2" Padding="12">
                            <TextBlock Text="Right Panel" Foreground="{hy:Color TextPrimary}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- 3. Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="SplitterColor" /><Run Text=" (Brush) - Color of the splitter bar" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SplitterThickness" /><Run Text=" (double) - Thickness of the splitter bar. Default: 4" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
