<UserControl
    x:Class="Docs.Mvvm.Styles.Components.FontSizeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="900"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- Title -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{hy:FontSize _2Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="Font Size Tokens" />
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Md}"
                    Foreground="{hy:Color TextSecondary}"
                    TextWrapping="Wrap"
                    Text="The HYSoft SDK provides a font size token system for consistent typography. Use tokens instead of hard-coded font sizes." />

                <!-- 1. Usage -->
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="1. Usage" />
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{hy:FontSize Md}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="- Use the hy:FontSize markup extension:" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;TextBlock FontSize=&quot;" />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="{}{hy:FontSize Md}" />
                            <Run Text="&quot; Text=&quot;Medium text&quot; /&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="&lt;TextBlock FontSize=&quot;" />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="{}{hy:FontSize Xl}" />
                            <Run Text="&quot; Text=&quot;Extra large heading&quot; /&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Token Reference -->
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="2. Token Reference" />

                <!-- Xs -->
                <Border Margin="0,0,0,12" Padding="12" Background="{hy:Color SurfaceElevated}" CornerRadius="4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock FontSize="{hy:FontSize Sm}" FontWeight="Bold" Foreground="{hy:Color TextPrimary}" Text="Xs" />
                            <TextBlock FontSize="{hy:FontSize Sm}" Foreground="{hy:Color TextSecondary}" Text=" = 12px" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock FontSize="{hy:FontSize Xs}" Foreground="{hy:Color TextPrimary}" Text="The quick brown fox jumps over the lazy dog (Xs = 12)" />
                    </StackPanel>
                </Border>

                <!-- Sm -->
                <Border Margin="0,0,0,12" Padding="12" Background="{hy:Color SurfaceElevated}" CornerRadius="4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock FontSize="{hy:FontSize Sm}" FontWeight="Bold" Foreground="{hy:Color TextPrimary}" Text="Sm" />
                            <TextBlock FontSize="{hy:FontSize Sm}" Foreground="{hy:Color TextSecondary}" Text=" = 14px" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock FontSize="{hy:FontSize Sm}" Foreground="{hy:Color TextPrimary}" Text="The quick brown fox jumps over the lazy dog (Sm = 14)" />
                    </StackPanel>
                </Border>

                <!-- Md -->
                <Border Margin="0,0,0,12" Padding="12" Background="{hy:Color SurfaceElevated}" CornerRadius="4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock FontSize="{hy:FontSize Sm}" FontWeight="Bold" Foreground="{hy:Color TextPrimary}" Text="Md" />
                            <TextBlock FontSize="{hy:FontSize Sm}" Foreground="{hy:Color TextSecondary}" Text=" = 16px (default)" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="The quick brown fox jumps over the lazy dog (Md = 16)" />
                    </StackPanel>
                </Border>

                <!-- Lg -->
                <Border Margin="0,0,0,12" Padding="12" Background="{hy:Color SurfaceElevated}" CornerRadius="4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock FontSize="{hy:FontSize Sm}" FontWeight="Bold" Foreground="{hy:Color TextPrimary}" Text="Lg" />
                            <TextBlock FontSize="{hy:FontSize Sm}" Foreground="{hy:Color TextSecondary}" Text=" = 20px" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock FontSize="{hy:FontSize Lg}" Foreground="{hy:Color TextPrimary}" Text="The quick brown fox jumps over the lazy dog (Lg = 20)" />
                    </StackPanel>
                </Border>

                <!-- Xl -->
                <Border Margin="0,0,0,12" Padding="12" Background="{hy:Color SurfaceElevated}" CornerRadius="4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock FontSize="{hy:FontSize Sm}" FontWeight="Bold" Foreground="{hy:Color TextPrimary}" Text="Xl" />
                            <TextBlock FontSize="{hy:FontSize Sm}" Foreground="{hy:Color TextSecondary}" Text=" = 24px" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="The quick brown fox jumps over the lazy dog (Xl = 24)" />
                    </StackPanel>
                </Border>

                <!-- _2Xl -->
                <Border Margin="0,0,0,12" Padding="12" Background="{hy:Color SurfaceElevated}" CornerRadius="4">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock FontSize="{hy:FontSize Sm}" FontWeight="Bold" Foreground="{hy:Color TextPrimary}" Text="_2Xl" />
                            <TextBlock FontSize="{hy:FontSize Sm}" Foreground="{hy:Color TextSecondary}" Text=" = 32px" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock FontSize="{hy:FontSize _2Xl}" Foreground="{hy:Color TextPrimary}" Text="The quick brown fox (2Xl = 32)" />
                    </StackPanel>
                </Border>

                <!-- 3. Customization -->
                <TextBlock
                    Margin="0,4,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="3. Customization" />
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{hy:FontSize Md}"
                    Foreground="{hy:Color TextPrimary}"
                    TextWrapping="Wrap"
                    Text="- Override font sizes by adding System.Double resources in App.xaml:" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;Application.Resources&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="    &lt;sys:Double x:Key=&quot;Md&quot;&gt;18&lt;/sys:Double&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="    &lt;sys:Double x:Key=&quot;Xl&quot;&gt;28&lt;/sys:Double&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="&lt;/Application.Resources&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="" />
                        </Paragraph>
                        <Paragraph>
                            <Run FontWeight="Bold" Foreground="{hy:Color TextInfo}" Text="&lt;!-- xmlns:sys=&quot;clr-namespace:System;assembly=mscorlib&quot; --&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
