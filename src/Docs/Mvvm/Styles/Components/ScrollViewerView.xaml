<UserControl
    x:Class="Docs.Mvvm.Styles.Components.ScrollViewerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyScrollViewer in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyScrollViewer " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="ThumbColor=&quot;Gray&quot; ScrollBarSize=&quot;8&quot;" />
                            <Run Text="&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;!-- Content --&gt;" />
                            <LineBreak />
                            <Run Text="&lt;/hy:HyScrollViewer&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Custom Scrollbar" />
                <Border BorderBrush="{hy:Color BorderDefault}" BorderThickness="1" Height="150" Margin="0,0,0,16">
                    <hy:HyScrollViewer ThumbColor="CornflowerBlue" ScrollBarSize="8" ThumbCornerRadius="4">
                        <StackPanel>
                            <TextBlock Margin="8" Text="Line 1" />
                            <TextBlock Margin="8" Text="Line 2" />
                            <TextBlock Margin="8" Text="Line 3" />
                            <TextBlock Margin="8" Text="Line 4" />
                            <TextBlock Margin="8" Text="Line 5" />
                            <TextBlock Margin="8" Text="Line 6" />
                            <TextBlock Margin="8" Text="Line 7" />
                            <TextBlock Margin="8" Text="Line 8" />
                            <TextBlock Margin="8" Text="Line 9" />
                            <TextBlock Margin="8" Text="Line 10" />
                        </StackPanel>
                    </hy:HyScrollViewer>
                </Border>

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Hide Arrow Buttons" />
                <Border BorderBrush="{hy:Color BorderDefault}" BorderThickness="1" Height="120" Margin="0,0,0,16">
                    <hy:HyScrollViewer RepeatButtonVisibility="Collapsed" ScrollBarSize="6" ThumbColor="Gray" ThumbCornerRadius="3">
                        <StackPanel>
                            <TextBlock Margin="8" Text="RepeatButtonVisibility=Collapsed hides arrow buttons." />
                            <TextBlock Margin="8" Text="Only the thumb is visible." />
                            <TextBlock Margin="8" Text="Line 3" />
                            <TextBlock Margin="8" Text="Line 4" />
                            <TextBlock Margin="8" Text="Line 5" />
                            <TextBlock Margin="8" Text="Line 6" />
                            <TextBlock Margin="8" Text="Line 7" />
                        </StackPanel>
                    </hy:HyScrollViewer>
                </Border>

                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="ThumbColor" /><Run Text=" (Brush) - Scrollbar thumb color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ThumbCornerRadius" /><Run Text=" (CornerRadius) - Thumb border radius" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ScrollBarSize" /><Run Text=" (double) - Scrollbar thickness. Default: 12" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ScrollBarBackground" /><Run Text=" (Brush) - Track background" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ScrollBarBorderBrush" /><Run Text=" (Brush) - Track border" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ScrollBarPadding" /><Run Text=" (Thickness) - Track padding" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="RepeatButtonVisibility" /><Run Text=" (Visibility) - Show/hide arrow buttons" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
