<UserControl
    x:Class="Docs.Mvvm.Styles.Components.TextBoxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyTextBox in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyTextBox " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="Watermark=&quot;Enter text&quot; CanKorean=&quot;False&quot; IsOnlyNumber=&quot;True&quot;" />
                            <Run Text=" /&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Default with Watermark" />
                <hy:HyTextBox Width="300" Height="32" HorizontalAlignment="Left" Margin="0,0,0,16"
                    Watermark="Enter text here" WatermarkForeground="{hy:Color TextWatermark}"
                    BorderBrush="{hy:Color BorderDefault}" BorderThickness="1" />

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="IsOnlyNumber=True (numeric only)" />
                <hy:HyTextBox Width="300" Height="32" HorizontalAlignment="Left" Margin="0,0,0,16"
                    Watermark="Numbers only" IsOnlyNumber="True"
                    WatermarkForeground="{hy:Color TextWatermark}"
                    BorderBrush="{hy:Color BorderDefault}" BorderThickness="1" />

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="CanKorean=False (block Korean IME)" />
                <hy:HyTextBox Width="300" Height="32" HorizontalAlignment="Left" Margin="0,0,0,16"
                    Watermark="Korean input blocked" CanKorean="False"
                    WatermarkForeground="{hy:Color TextWatermark}"
                    BorderBrush="{hy:Color BorderDefault}" BorderThickness="1" />

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="CanPaste=False (paste blocked)" />
                <hy:HyTextBox Width="300" Height="32" HorizontalAlignment="Left" Margin="0,0,0,16"
                    Watermark="Paste disabled" CanPaste="False"
                    WatermarkForeground="{hy:Color TextWatermark}"
                    BorderBrush="{hy:Color BorderDefault}" BorderThickness="1" />

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="CornerRadius" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <hy:HyTextBox Width="150" Height="32" Margin="0,0,8,0" Text="Radius 0" CornerRadius="0"
                        BorderBrush="{hy:Color BorderDefault}" BorderThickness="1" />
                    <hy:HyTextBox Width="150" Height="32" Text="Radius 8" CornerRadius="8"
                        BorderBrush="{hy:Color BorderDefault}" BorderThickness="1" />
                </StackPanel>

                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Custom Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="Watermark" /><Run Text=" (string) - Placeholder text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="WatermarkForeground" /><Run Text=" (SolidColorBrush) - Placeholder color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="CornerRadius" /><Run Text=" (CornerRadius) - Border radius" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsOnlyNumber" /><Run Text=" (bool) - Restrict to numeric input. Default: false" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="CanKorean" /><Run Text=" (bool) - Allow Korean IME. Default: true" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="CanPaste" /><Run Text=" (bool) - Allow paste. Default: true" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="4. Base Properties (inherited)" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="Text" /><Run Text=" (string) - The text content of the TextBox" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsReadOnly" /><Run Text=" (bool) - Whether the text is read-only" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="MaxLength" /><Run Text=" (int) - Maximum number of characters allowed" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="TextAlignment" /><Run Text=" (TextAlignment) - Text alignment (Left, Center, Right)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="AcceptsReturn" /><Run Text=" (bool) - Whether Enter key inserts a new line" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="TextWrapping" /><Run Text=" (TextWrapping) - How text wraps (NoWrap, Wrap, WrapWithOverflow)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Background" /><Run Text=" (Brush) - Control background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Foreground" /><Run Text=" (Brush) - Text/content color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontSize" /><Run Text=" (double) - Font size of content text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontWeight" /><Run Text=" (FontWeight) - Font weight of content text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Padding" /><Run Text=" (Thickness) - Inner spacing between border and content" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Margin" /><Run Text=" (Thickness) - Outer spacing around the control" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Width" /><Run Text=" (double) - Control width" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Height" /><Run Text=" (double) - Control height" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="HorizontalAlignment" /><Run Text=" (HorizontalAlignment) - Horizontal alignment within parent" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="VerticalAlignment" /><Run Text=" (VerticalAlignment) - Vertical alignment within parent" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsEnabled" /><Run Text=" (bool) - Whether the control is interactive" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Visibility" /><Run Text=" (Visibility) - Control visibility (Visible, Hidden, Collapsed)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Opacity" /><Run Text=" (double) - Control opacity (0.0 to 1.0)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Cursor" /><Run Text=" (Cursor) - Mouse cursor when hovering" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ToolTip" /><Run Text=" (object) - Tooltip shown on hover" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
