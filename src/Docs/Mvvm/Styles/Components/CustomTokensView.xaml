<UserControl
    x:Class="Docs.Mvvm.Styles.Components.CustomTokensView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="900"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- Title -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{hy:FontSize _2Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="Custom Color Tokens" />
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Md}"
                    Foreground="{hy:Color TextSecondary}"
                    TextWrapping="Wrap"
                    Text="You can override the default color tokens by defining SolidColorBrush resources with the same keys in your App.xaml. The SDK uses a fallback mechanism: app resources take priority over package defaults." />

                <!-- 1. How It Works -->
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="1. How It Works" />
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{hy:FontSize Md}"
                    Foreground="{hy:Color TextPrimary}"
                    TextWrapping="Wrap"
                    Text="- The ColorGenerator resolves tokens in this order:" />
                <TextBlock
                    Margin="16,0,0,4"
                    FontSize="{hy:FontSize Sm}"
                    Foreground="{hy:Color TextSecondary}"
                    Text="1) Application.Current.TryFindResource(key) - your App.xaml overrides" />
                <TextBlock
                    Margin="16,0,0,4"
                    FontSize="{hy:FontSize Sm}"
                    Foreground="{hy:Color TextSecondary}"
                    Text="2) Package XAML (ColorSemantics.xaml) - built-in defaults" />
                <TextBlock
                    Margin="16,0,0,16"
                    FontSize="{hy:FontSize Sm}"
                    Foreground="{hy:Color TextSecondary}"
                    Text="3) Fallback Transparent brush if not found" />

                <!-- 2. Override in App.xaml -->
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="2. Override in App.xaml" />
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{hy:FontSize Md}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="- Add SolidColorBrush entries with matching x:Key values:" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;Application.Resources&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="    &lt;ResourceDictionary&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="        " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextInfo}" Text="&lt;!-- Override default color tokens --&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="        &lt;SolidColorBrush x:Key=&quot;" />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="TextPrimary" />
                            <Run Text="&quot;&gt;#333333&lt;/SolidColorBrush&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="        &lt;SolidColorBrush x:Key=&quot;" />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="ButtonPrimaryBg" />
                            <Run Text="&quot;&gt;#1E90FF&lt;/SolidColorBrush&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="        &lt;SolidColorBrush x:Key=&quot;" />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="SurfaceBase" />
                            <Run Text="&quot;&gt;#FAFAFA&lt;/SolidColorBrush&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="        " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextInfo}" Text="&lt;!-- Merge the HYSoft theme after your overrides --&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="        &lt;ResourceDictionary.MergedDictionaries&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="            &lt;hy:HySoftTheme /&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="        &lt;/ResourceDictionary.MergedDictionaries&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="    &lt;/ResourceDictionary&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="&lt;/Application.Resources&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 3. Available Keys -->
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="3. Available Keys" />
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="{hy:FontSize Md}"
                    Foreground="{hy:Color TextPrimary}"
                    TextWrapping="Wrap"
                    Text="- Use the same x:Key strings defined in ColorSemantics.xaml. All keys from the Default Tokens page can be overridden:" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="Text: " />
                            <Run Text="TextPrimary, TextSecondary, TextTertiary, TextDisabled, TextInverse, TextLink, TextError, TextSuccess, TextWarning, TextInfo, TextWatermark" />
                        </Paragraph>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="Icon: " />
                            <Run Text="IconDefault, IconInverse, IconDisabled, IconSuccess, IconWarning, IconError, IconInfo" />
                        </Paragraph>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="Surface: " />
                            <Run Text="SurfaceBase, SurfaceSubtle, SurfaceElevated, SurfaceInverse, SurfaceOverlay" />
                        </Paragraph>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="Border: " />
                            <Run Text="BorderSubtle, BorderDefault, BorderStrong, BorderDivider, BorderFocus, BorderError, BorderSuccess, BorderWarning" />
                        </Paragraph>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="Button: " />
                            <Run Text="ButtonPrimary(Fg/Bg/Border), ButtonSecondary(Fg/Bg/Border), ButtonTertiary(Fg/Bg/Border), ButtonDestructive(Fg/Bg/Border)" />
                        </Paragraph>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="Input: " />
                            <Run Text="InputBg, InputFg, InputPlaceholder, InputBorder, InputHelperText, InputErrorText" />
                        </Paragraph>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="Others: " />
                            <Run Text="Feedback*, Badge*, Table*, Navigation*, Selection*, Scrollbar*, TitleBar*, Popup*" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 4. Tips -->
                <TextBlock
                    Margin="0,0,0,16"
                    FontSize="{hy:FontSize Xl}"
                    Foreground="{hy:Color TextPrimary}"
                    Text="4. Tips" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="Partial override: " />
                            <Run Text="You only need to override the tokens you want to change. All others will use the package defaults." />
                        </Paragraph>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="FontSize tokens: " />
                            <Run Text="FontSize tokens (Xs, Sm, Md, Lg, Xl, _2Xl) use the same fallback mechanism. Override them by adding System.Double resources with matching keys." />
                        </Paragraph>
                        <Paragraph>
                            <Run FontWeight="Bold" Text="Order matters: " />
                            <Run Text="Place your overrides before the HySoftTheme MergedDictionary so they take precedence during resolution." />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
