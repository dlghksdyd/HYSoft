<UserControl
    x:Class="Docs.Mvvm.Styles.Components.DataGridView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}"
                    Text="- Use HyDataGrid in XAML. It applies Table color tokens automatically." />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="&lt;hy:HyDataGrid AutoGenerateColumns=&quot;False&quot; CornerRadius=&quot;4&quot;&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;hy:HyDataGrid.Columns&gt;" />
                            <LineBreak />
                            <Run Text="        &lt;DataGridTextColumn Header=&quot;Name&quot; Binding=&quot;{Binding Name}&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="        &lt;DataGridTextColumn Header=&quot;Value&quot; Binding=&quot;{Binding Value}&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="    &lt;/hy:HyDataGrid.Columns&gt;" />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="&lt;/hy:HyDataGrid&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- Default -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Default" />
                <hy:HyDataGrid Height="180" Margin="0,0,0,16" AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True">
                    <hy:HyDataGrid.Columns>
                        <DataGridTextColumn Header="Name" Width="*" />
                        <DataGridTextColumn Header="Type" Width="*" />
                        <DataGridTextColumn Header="Default" Width="*" />
                    </hy:HyDataGrid.Columns>
                </hy:HyDataGrid>

                <!-- CornerRadius -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="CornerRadius" />
                <hy:HyDataGrid Height="150" Margin="0,0,0,16" AutoGenerateColumns="False" CornerRadius="8" HeadersVisibility="Column" IsReadOnly="True">
                    <hy:HyDataGrid.Columns>
                        <DataGridTextColumn Header="Column A" Width="*" />
                        <DataGridTextColumn Header="Column B" Width="*" />
                        <DataGridTextColumn Header="Column C" Width="*" />
                    </hy:HyDataGrid.Columns>
                </hy:HyDataGrid>

                <!-- Color Tokens -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Table Color Tokens" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="TableHeader" /><Run Text=" - Header row background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="TableRow" /><Run Text=" - Default row background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="TableRowAlternate" /><Run Text=" - Alternate row background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="TableRowHover" /><Run Text=" - Row hover background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="TableRowSelected" /><Run Text=" - Selected row background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="TableBorder" /><Run Text=" - Grid line and border color" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 3. Custom Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Custom Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="CornerRadius" /><Run Text=" (CornerRadius) - DataGrid border corner radius" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 4. Base Properties (inherited) -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="4. Base Properties (inherited)" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="Background" /><Run Text=" (Brush) - Control background color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Foreground" /><Run Text=" (Brush) - Text color" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontSize" /><Run Text=" (double) - Font size" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontWeight" /><Run Text=" (FontWeight) - Font weight" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Padding" /><Run Text=" (Thickness) - Inner padding" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Margin" /><Run Text=" (Thickness) - Outer margin" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Width" /><Run Text=" (double) - Control width" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Height" /><Run Text=" (double) - Control height" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="HorizontalAlignment" /><Run Text=" (HorizontalAlignment) - Horizontal alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="VerticalAlignment" /><Run Text=" (VerticalAlignment) - Vertical alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsEnabled" /><Run Text=" (bool) - Whether the control is enabled" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Visibility" /><Run Text=" (Visibility) - Control visibility" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Opacity" /><Run Text=" (double) - Control opacity (0.0 to 1.0)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Cursor" /><Run Text=" (Cursor) - Mouse cursor when hovering" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ToolTip" /><Run Text=" (object) - Tooltip content" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ItemsSource" /><Run Text=" (IEnumerable) - Data source for grid rows" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SelectedItem" /><Run Text=" (object) - Currently selected row item" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SelectedIndex" /><Run Text=" (int) - Index of the selected row" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="AutoGenerateColumns" /><Run Text=" (bool) - Auto-generate columns from data source" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="CanUserSortColumns" /><Run Text=" (bool) - Whether users can sort by clicking headers" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="CanUserResizeColumns" /><Run Text=" (bool) - Whether users can resize columns" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SelectionMode" /><Run Text=" (DataGridSelectionMode) - Single or Extended selection" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SelectionUnit" /><Run Text=" (DataGridSelectionUnit) - Cell, FullRow, or CellOrRowHeader" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="GridLinesVisibility" /><Run Text=" (DataGridGridLinesVisibility) - Which grid lines to show" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="RowHeaderWidth" /><Run Text=" (double) - Width of row headers" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
