<UserControl
    x:Class="Docs.Mvvm.Styles.Components.DialogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}"
                    Text="- HyDialog is a modal dialog window with a title, message, and action buttons." />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="&lt;hy:HyDialog" />
                            <LineBreak />
                            <Run Text="    DialogTitle=&quot;Confirm&quot;" />
                            <LineBreak />
                            <Run Text="    DialogMessage=&quot;Are you sure?&quot;" />
                            <LineBreak />
                            <Run Text="    ConfirmButtonText=&quot;OK&quot;" />
                            <LineBreak />
                            <Run Text="    CancelButtonText=&quot;Cancel&quot;" />
                            <LineBreak />
                            <Run Text="    ShowCancelButton=&quot;True&quot;" />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text=" /&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Usage" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Sm}" Foreground="{hy:Color TextSecondary}"
                    Text="HyDialog opens as a separate modal window. It cannot be embedded inside a view. Create and show it from code-behind or a ViewModel command." />

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Confirm Dialog" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="var dialog = new HyDialog" />
                            <LineBreak />
                            <Run Text="{}{" />
                            <LineBreak />
                            <Run Text="    DialogTitle = &quot;Confirm&quot;," />
                            <LineBreak />
                            <Run Text="    DialogMessage = &quot;Are you sure you want to proceed?&quot;," />
                            <LineBreak />
                            <Run Text="    ConfirmButtonText = &quot;OK&quot;," />
                            <LineBreak />
                            <Run Text="    CancelButtonText = &quot;Cancel&quot;," />
                            <LineBreak />
                            <Run Text="    ShowCancelButton = true" />
                            <LineBreak />
                            <Run Text="{}}};" />
                            <LineBreak />
                            <Run Text="dialog.ShowDialog();" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Alert Dialog (No Cancel)" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="var alert = new HyDialog" />
                            <LineBreak />
                            <Run Text="{}{" />
                            <LineBreak />
                            <Run Text="    DialogTitle = &quot;Notice&quot;," />
                            <LineBreak />
                            <Run Text="    DialogMessage = &quot;Operation completed.&quot;," />
                            <LineBreak />
                            <Run Text="    ConfirmButtonText = &quot;OK&quot;," />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="    ShowCancelButton = false" />
                            <LineBreak />
                            <Run Text="{}}};" />
                            <LineBreak />
                            <Run Text="alert.ShowDialog();" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 3. Custom Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Custom Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="CornerRadius" /><Run Text=" (CornerRadius) - Dialog corner radius. Default: 8" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="DialogTitle" /><Run Text=" (string) - Title text displayed at the top of the dialog" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="DialogMessage" /><Run Text=" (string) - Message body text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ConfirmButtonText" /><Run Text=" (string) - Confirm button label. Default: &quot;OK&quot;" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="CancelButtonText" /><Run Text=" (string) - Cancel button label. Default: &quot;Cancel&quot;" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ShowCancelButton" /><Run Text=" (bool) - Whether to show the cancel button. Default: true" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 4. Base Properties (inherited) -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="4. Base Properties (inherited)" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="Title" /><Run Text=" (string) - Window title text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="WindowState" /><Run Text=" (WindowState) - Window state (Normal, Minimized, Maximized)" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="WindowStartupLocation" /><Run Text=" (WindowStartupLocation) - Startup position of the window" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ResizeMode" /><Run Text=" (ResizeMode) - Resize behavior of the window" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ShowInTaskbar" /><Run Text=" (bool) - Whether the window appears in the taskbar. Default: true" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Topmost" /><Run Text=" (bool) - Whether the window stays on top. Default: false" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Owner" /><Run Text=" (Window) - Owner window for modality" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SizeToContent" /><Run Text=" (SizeToContent) - Automatic sizing behavior" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Background" /><Run Text=" (Brush) - Background brush" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Foreground" /><Run Text=" (Brush) - Foreground brush" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontSize" /><Run Text=" (double) - Font size" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontWeight" /><Run Text=" (FontWeight) - Font weight" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Padding" /><Run Text=" (Thickness) - Inner padding" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Margin" /><Run Text=" (Thickness) - Outer margin" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Width" /><Run Text=" (double) - Element width" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Height" /><Run Text=" (double) - Element height" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="HorizontalAlignment" /><Run Text=" (HorizontalAlignment) - Horizontal alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="VerticalAlignment" /><Run Text=" (VerticalAlignment) - Vertical alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsEnabled" /><Run Text=" (bool) - Whether the control is enabled. Default: true" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Visibility" /><Run Text=" (Visibility) - Control visibility" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Opacity" /><Run Text=" (double) - Opacity level. Default: 1.0" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Cursor" /><Run Text=" (Cursor) - Mouse cursor when hovering" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ToolTip" /><Run Text=" (object) - Tooltip content" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
