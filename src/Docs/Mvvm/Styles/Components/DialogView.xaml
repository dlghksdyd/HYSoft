<UserControl
    x:Class="Docs.Mvvm.Styles.Components.DialogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}"
                    Text="- HyDialog is a modal dialog window with a title, message, and action buttons." />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="&lt;hy:HyDialog" />
                            <LineBreak />
                            <Run Text="    DialogTitle=&quot;Confirm&quot;" />
                            <LineBreak />
                            <Run Text="    DialogMessage=&quot;Are you sure?&quot;" />
                            <LineBreak />
                            <Run Text="    ConfirmButtonText=&quot;OK&quot;" />
                            <LineBreak />
                            <Run Text="    CancelButtonText=&quot;Cancel&quot;" />
                            <LineBreak />
                            <Run Text="    ShowCancelButton=&quot;True&quot;" />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text=" /&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Usage" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Sm}" Foreground="{hy:Color TextSecondary}"
                    Text="HyDialog opens as a separate modal window. It cannot be embedded inside a view. Create and show it from code-behind or a ViewModel command." />

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Confirm Dialog" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="var dialog = new HyDialog" />
                            <LineBreak />
                            <Run Text="{}{" />
                            <LineBreak />
                            <Run Text="    DialogTitle = &quot;Confirm&quot;," />
                            <LineBreak />
                            <Run Text="    DialogMessage = &quot;Are you sure you want to proceed?&quot;," />
                            <LineBreak />
                            <Run Text="    ConfirmButtonText = &quot;OK&quot;," />
                            <LineBreak />
                            <Run Text="    CancelButtonText = &quot;Cancel&quot;," />
                            <LineBreak />
                            <Run Text="    ShowCancelButton = true" />
                            <LineBreak />
                            <Run Text="{}}};" />
                            <LineBreak />
                            <Run Text="dialog.ShowDialog();" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Alert Dialog (No Cancel)" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="var alert = new HyDialog" />
                            <LineBreak />
                            <Run Text="{}{" />
                            <LineBreak />
                            <Run Text="    DialogTitle = &quot;Notice&quot;," />
                            <LineBreak />
                            <Run Text="    DialogMessage = &quot;Operation completed.&quot;," />
                            <LineBreak />
                            <Run Text="    ConfirmButtonText = &quot;OK&quot;," />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="    ShowCancelButton = false" />
                            <LineBreak />
                            <Run Text="{}}};" />
                            <LineBreak />
                            <Run Text="alert.ShowDialog();" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 3. Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="CornerRadius" /><Run Text=" (CornerRadius) - Dialog corner radius. Default: 8" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="DialogTitle" /><Run Text=" (string) - Title text displayed at the top of the dialog" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="DialogMessage" /><Run Text=" (string) - Message body text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ConfirmButtonText" /><Run Text=" (string) - Confirm button label. Default: &quot;OK&quot;" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="CancelButtonText" /><Run Text=" (string) - Cancel button label. Default: &quot;Cancel&quot;" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ShowCancelButton" /><Run Text=" (bool) - Whether to show the cancel button. Default: true" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
