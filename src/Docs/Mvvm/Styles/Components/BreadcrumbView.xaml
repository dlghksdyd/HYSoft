<UserControl
    x:Class="Docs.Mvvm.Styles.Components.BreadcrumbView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyBreadcrumb with HyBreadcrumbItem in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyBreadcrumb&gt;" />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="  &lt;hy:HyBreadcrumbItem Content=&quot;Home&quot; /&gt;" />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="  &lt;hy:HyBreadcrumbItem Content=&quot;Products&quot; /&gt;" />
                            <LineBreak />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="  &lt;hy:HyBreadcrumbItem Content=&quot;Details&quot; IsLast=&quot;True&quot; /&gt;" />
                            <LineBreak />
                            <Run Text="&lt;/hy:HyBreadcrumb&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- Default -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Default Breadcrumb" />
                <hy:HyBreadcrumb Margin="0,0,0,16" HorizontalAlignment="Left">
                    <hy:HyBreadcrumbItem Content="Home" />
                    <hy:HyBreadcrumbItem Content="Products" />
                    <hy:HyBreadcrumbItem Content="Details" IsLast="True" />
                </hy:HyBreadcrumb>

                <!-- Custom Separator -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Custom Separator" />
                <hy:HyBreadcrumb Margin="0,0,0,16" HorizontalAlignment="Left" Separator="/">
                    <hy:HyBreadcrumbItem Content="Home" />
                    <hy:HyBreadcrumbItem Content="Settings" />
                    <hy:HyBreadcrumbItem Content="Profile" IsLast="True" />
                </hy:HyBreadcrumb>

                <!-- Longer path -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Longer Path" />
                <hy:HyBreadcrumb Margin="0,0,0,16" HorizontalAlignment="Left">
                    <hy:HyBreadcrumbItem Content="Home" />
                    <hy:HyBreadcrumbItem Content="Category" />
                    <hy:HyBreadcrumbItem Content="Subcategory" />
                    <hy:HyBreadcrumbItem Content="Item" IsLast="True" />
                </hy:HyBreadcrumb>

                <!-- 3. Custom Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Custom Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph FontWeight="Bold"><Run Text="HyBreadcrumb" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Separator" /><Run Text=" (string) - Separator character between items. Default: &quot;>&quot;" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="SeparatorForeground" /><Run Text=" (Brush) - Color of the separator" /></Paragraph>
                        <Paragraph />
                        <Paragraph FontWeight="Bold"><Run Text="HyBreadcrumbItem" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsLast" /><Run Text=" (bool) - Marks the last item (no separator after). Default: false" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 4. Base Properties (inherited) -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="4. Base Properties (inherited)" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="ItemsSource" /><Run Text=" (IEnumerable) - Data source for breadcrumb items" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ItemTemplate" /><Run Text=" (DataTemplate) - Template for each breadcrumb item" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ItemTemplateSelector" /><Run Text=" (DataTemplateSelector) - Selector for item templates" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="DisplayMemberPath" /><Run Text=" (string) - Property path for display text" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Background" /><Run Text=" (Brush) - Background brush" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Foreground" /><Run Text=" (Brush) - Foreground brush" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontSize" /><Run Text=" (double) - Font size" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="FontWeight" /><Run Text=" (FontWeight) - Font weight" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Padding" /><Run Text=" (Thickness) - Inner padding" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Margin" /><Run Text=" (Thickness) - Outer margin" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Width" /><Run Text=" (double) - Element width" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Height" /><Run Text=" (double) - Element height" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="HorizontalAlignment" /><Run Text=" (HorizontalAlignment) - Horizontal alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="VerticalAlignment" /><Run Text=" (VerticalAlignment) - Vertical alignment" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="IsEnabled" /><Run Text=" (bool) - Whether the control is enabled. Default: true" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Visibility" /><Run Text=" (Visibility) - Control visibility" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Opacity" /><Run Text=" (double) - Opacity level. Default: 1.0" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="Cursor" /><Run Text=" (Cursor) - Mouse cursor when hovering" /></Paragraph>
                        <Paragraph><Run FontWeight="Bold" Text="ToolTip" /><Run Text=" (object) - Tooltip content" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
