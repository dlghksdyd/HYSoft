<UserControl
    x:Class="Docs.Mvvm.Styles.Components.TreeViewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:Docs.Mvvm.Styles.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:Background="{hy:Color SurfaceBase}"
    d:DataContext="{d:DesignInstance local:ComponentViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="900" d:DesignWidth="800"
    mc:Ignorable="d">
    <Border Margin="20">
        <hy:HyScrollViewer>
            <StackPanel Margin="0,0,10,0" Orientation="Vertical">
                <!-- 1. Getting Started -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="1. Getting Started" />
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="- Use HyTreeView / HyTreeViewItem in XAML" />
                <RichTextBox Margin="0,0,0,16" Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="&lt;hy:HyTreeView&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="    &lt;hy:HyTreeViewItem " />
                            <Run FontWeight="Bold" Foreground="{hy:Color TextError}" Text="Header=&quot;Root&quot;" />
                            <Run Text="&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="        &lt;hy:HyTreeViewItem Header=&quot;Child&quot; /&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="    &lt;/hy:HyTreeViewItem&gt;" />
                        </Paragraph>
                        <Paragraph>
                            <Run Text="&lt;/hy:HyTreeView&gt;" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <!-- 2. Examples -->
                <TextBlock Margin="0,0,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="2. Examples" />

                <!-- Nested TreeView -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="Nested TreeView (3 Levels)" />
                <hy:HyTreeView Margin="0,0,0,16">
                    <hy:HyTreeViewItem Header="Documents" IsExpanded="True">
                        <hy:HyTreeViewItem Header="Work" IsExpanded="True">
                            <hy:HyTreeViewItem Header="Report.docx" />
                            <hy:HyTreeViewItem Header="Presentation.pptx" />
                            <hy:HyTreeViewItem Header="Budget.xlsx" />
                        </hy:HyTreeViewItem>
                        <hy:HyTreeViewItem Header="Personal">
                            <hy:HyTreeViewItem Header="Notes.txt" />
                            <hy:HyTreeViewItem Header="Photos">
                                <hy:HyTreeViewItem Header="Vacation.jpg" />
                                <hy:HyTreeViewItem Header="Family.png" />
                            </hy:HyTreeViewItem>
                        </hy:HyTreeViewItem>
                    </hy:HyTreeViewItem>
                    <hy:HyTreeViewItem Header="Downloads">
                        <hy:HyTreeViewItem Header="Setup.exe" />
                        <hy:HyTreeViewItem Header="Archive.zip" />
                    </hy:HyTreeViewItem>
                    <hy:HyTreeViewItem Header="Desktop">
                        <hy:HyTreeViewItem Header="Shortcut.lnk" />
                    </hy:HyTreeViewItem>
                </hy:HyTreeView>

                <!-- CornerRadius -->
                <TextBlock Margin="0,0,0,8" FontSize="{hy:FontSize Md}" Foreground="{hy:Color TextPrimary}" Text="CornerRadius" />
                <hy:HyTreeView Margin="0,0,0,16" CornerRadius="8">
                    <hy:HyTreeViewItem Header="Root with CornerRadius=8" IsExpanded="True">
                        <hy:HyTreeViewItem Header="Child A" />
                        <hy:HyTreeViewItem Header="Child B" />
                    </hy:HyTreeViewItem>
                </hy:HyTreeView>

                <!-- 3. Properties -->
                <TextBlock Margin="0,16,0,16" FontSize="{hy:FontSize Xl}" Foreground="{hy:Color TextPrimary}" Text="3. Properties" />
                <RichTextBox Padding="8" FontSize="{hy:FontSize Sm}" IsReadOnly="True">
                    <FlowDocument>
                        <Paragraph><Run FontWeight="Bold" Text="CornerRadius" /><Run Text=" (CornerRadius) - Border corner radius of the TreeView" /></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </StackPanel>
        </hy:HyScrollViewer>
    </Border>
</UserControl>
