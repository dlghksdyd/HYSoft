<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:HYSoft.Presentation.Styles.ColorTokens"
    xmlns:local="clr-namespace:HYSoft.Presentation.Styles.Controls">

    <!-- Transparent RepeatButton for Slider track areas -->
    <Style x:Key="SliderRepeatButtonTransparent" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Rectangle Fill="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Filled portion RepeatButton (selection range) -->
    <Style x:Key="SliderRepeatButtonFilled" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border
                        Height="{Binding TrackHeight, RelativeSource={RelativeSource AncestorType=local:HySlider}}"
                        Background="{c:Color ButtonPrimaryBg}"
                        CornerRadius="{Binding TrackCornerRadius, RelativeSource={RelativeSource AncestorType=local:HySlider}}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Thumb -->
    <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid>
                        <!-- Hover highlight (slightly larger circle behind thumb) -->
                        <Ellipse
                            x:Name="ThumbHover"
                            Width="{Binding ThumbSize, RelativeSource={RelativeSource AncestorType=local:HySlider}}"
                            Height="{Binding ThumbSize, RelativeSource={RelativeSource AncestorType=local:HySlider}}"
                            Fill="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                        <!-- Main thumb circle -->
                        <Ellipse
                            x:Name="ThumbCircle"
                            Width="{Binding ThumbSize, RelativeSource={RelativeSource AncestorType=local:HySlider}}"
                            Height="{Binding ThumbSize, RelativeSource={RelativeSource AncestorType=local:HySlider}}"
                            Fill="{c:Color ButtonPrimaryBg}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbCircle" Property="Stroke" Value="{c:Color ButtonPrimaryBorder}" />
                            <Setter TargetName="ThumbCircle" Property="StrokeThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbCircle" Property="Stroke" Value="{c:Color ButtonPrimaryBorder}" />
                            <Setter TargetName="ThumbCircle" Property="StrokeThickness" Value="2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- HySlider Horizontal Template -->
    <ControlTemplate x:Key="HySliderHorizontalTemplate" TargetType="{x:Type local:HySlider}">
        <Grid SnapsToDevicePixels="True">
            <!-- Track background -->
            <Border
                x:Name="TrackBackground"
                Height="{TemplateBinding TrackHeight}"
                VerticalAlignment="Center"
                Background="{c:Color BorderSubtle}"
                CornerRadius="{TemplateBinding TrackCornerRadius}" />

            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource SliderRepeatButtonFilled}" />
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource SliderRepeatButtonTransparent}" />
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource SliderThumbStyle}" />
                </Track.Thumb>
            </Track>
        </Grid>

        <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- HySlider Vertical Template -->
    <ControlTemplate x:Key="HySliderVerticalTemplate" TargetType="{x:Type local:HySlider}">
        <Grid SnapsToDevicePixels="True">
            <!-- Track background -->
            <Border
                x:Name="TrackBackground"
                Width="{TemplateBinding TrackHeight}"
                HorizontalAlignment="Center"
                Background="{c:Color BorderSubtle}"
                CornerRadius="{TemplateBinding TrackCornerRadius}" />

            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource SliderRepeatButtonTransparent}" />
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource SliderRepeatButtonFilled}" />
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource SliderThumbStyle}" />
                </Track.Thumb>
            </Track>
        </Grid>

        <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- HySlider Style -->
    <Style TargetType="{x:Type local:HySlider}">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="TrackHeight" Value="4" />
        <Setter Property="ThumbSize" Value="16" />
        <Setter Property="TrackCornerRadius" Value="2" />
        <Setter Property="Template" Value="{StaticResource HySliderHorizontalTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Template" Value="{StaticResource HySliderVerticalTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
