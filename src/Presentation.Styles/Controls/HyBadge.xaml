<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:HYSoft.Presentation.Styles.ColorTokens"
    xmlns:local="clr-namespace:HYSoft.Presentation.Styles.Controls">

    <Style TargetType="{x:Type local:HyBadge}">
        <Setter Property="Background" Value="{c:Color BadgeNeutralBg}" />
        <Setter Property="Foreground" Value="{c:Color BadgeNeutralFg}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HyBadge}">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                        <TextBlock
                            Text="{TemplateBinding Text}"
                            Foreground="{TemplateBinding Foreground}"
                            FontSize="{TemplateBinding FontSize}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="BadgeType" Value="Neutral">
                <Setter Property="Background" Value="{c:Color BadgeNeutralBg}" />
                <Setter Property="Foreground" Value="{c:Color BadgeNeutralFg}" />
            </Trigger>
            <Trigger Property="BadgeType" Value="Info">
                <Setter Property="Background" Value="{c:Color BadgeInfoBg}" />
                <Setter Property="Foreground" Value="{c:Color BadgeInfoFg}" />
            </Trigger>
            <Trigger Property="BadgeType" Value="Success">
                <Setter Property="Background" Value="{c:Color BadgeSuccessBg}" />
                <Setter Property="Foreground" Value="{c:Color BadgeSuccessFg}" />
            </Trigger>
            <Trigger Property="BadgeType" Value="Warning">
                <Setter Property="Background" Value="{c:Color BadgeWarningBg}" />
                <Setter Property="Foreground" Value="{c:Color BadgeWarningFg}" />
            </Trigger>
            <Trigger Property="BadgeType" Value="Error">
                <Setter Property="Background" Value="{c:Color BadgeErrorBg}" />
                <Setter Property="Foreground" Value="{c:Color BadgeErrorFg}" />
            </Trigger>
            <Trigger Property="BadgeType" Value="Highlight">
                <Setter Property="Background" Value="{c:Color BadgeHighlightBg}" />
                <Setter Property="Foreground" Value="{c:Color BadgeHighlightFg}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
