<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:HYSoft.Presentation.Styles.ColorTokens"
    xmlns:local="clr-namespace:HYSoft.Presentation.Styles.Controls">

    <Style TargetType="{x:Type local:HyDialog}">
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="AllowsTransparency" Value="True" />
        <Setter Property="SizeToContent" Value="WidthAndHeight" />
        <Setter Property="WindowStartupLocation" Value="CenterOwner" />
        <Setter Property="Background" Value="{c:Color SurfaceElevated}" />
        <Setter Property="BorderBrush" Value="{c:Color BorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinWidth" Value="320" />
        <Setter Property="MinHeight" Value="160" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HyDialog}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="20"
                                Direction="270"
                                Opacity="0.3"
                                ShadowDepth="4"
                                Color="#000000" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Title area  -->
                            <TextBlock
                                Grid.Row="0"
                                Margin="24,20,24,0"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{c:Color TextPrimary}"
                                Text="{TemplateBinding DialogTitle}"
                                TextWrapping="Wrap" />

                            <!--  Message area  -->
                            <TextBlock
                                Grid.Row="1"
                                Margin="24,12,24,20"
                                FontSize="14"
                                Foreground="{c:Color TextSecondary}"
                                Text="{TemplateBinding DialogMessage}"
                                TextWrapping="Wrap" />

                            <!--  Button bar  -->
                            <StackPanel
                                Grid.Row="2"
                                Margin="24,0,24,20"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <local:HyButton
                                    x:Name="PART_CancelButton"
                                    MinWidth="80"
                                    Padding="16,8"
                                    Background="{c:Color ButtonSecondaryBg}"
                                    Content="{TemplateBinding CancelButtonText}"
                                    CornerRadius="4"
                                    FontSize="14"
                                    Foreground="{c:Color ButtonSecondaryFg}">
                                    <local:HyButton.Style>
                                        <Style TargetType="local:HyButton">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowCancelButton, RelativeSource={RelativeSource TemplatedParent}}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </local:HyButton.Style>
                                </local:HyButton>
                                <local:HyButton
                                    x:Name="PART_ConfirmButton"
                                    MinWidth="80"
                                    Margin="8,0,0,0"
                                    Padding="16,8"
                                    Background="{c:Color ButtonPrimaryBg}"
                                    Content="{TemplateBinding ConfirmButtonText}"
                                    CornerRadius="4"
                                    FontSize="14"
                                    Foreground="{c:Color ButtonPrimaryFg}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
