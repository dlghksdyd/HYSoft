<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:HYSoft.Presentation.Styles.ColorTokens"
    xmlns:local="clr-namespace:HYSoft.Presentation.Styles.Controls">

    <Style TargetType="{x:Type local:HyToggleSwitch}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OffBackground" Value="{c:Color BorderDefault}" />
        <Setter Property="OnBackground" Value="{c:Color ButtonPrimaryBg}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HyToggleSwitch}">
                    <Border
                        x:Name="Track"
                        Width="{TemplateBinding SwitchWidth}"
                        Height="{TemplateBinding SwitchHeight}"
                        Background="{TemplateBinding OffBackground}"
                        CornerRadius="{Binding SwitchHeight, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static local:HyToggleSwitch.HalfConverter}}">
                        <Ellipse
                            x:Name="PART_Thumb"
                            Width="{TemplateBinding ThumbSize}"
                            Height="{TemplateBinding ThumbSize}"
                            HorizontalAlignment="Left"
                            Margin="3,0,3,0"
                            Fill="White">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="PART_ThumbTranslate" X="0" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Checked: change track color -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{Binding OnBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>

                        <!-- Keyboard Focus -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{c:Color ButtonPrimaryBg}" />
                            <Setter TargetName="Track" Property="BorderThickness" Value="1.5" />
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
