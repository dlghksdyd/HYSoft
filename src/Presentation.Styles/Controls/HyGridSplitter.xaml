<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:HYSoft.Presentation.Styles.ColorTokens"
    xmlns:local="clr-namespace:HYSoft.Presentation.Styles.Controls">

    <Style TargetType="{x:Type local:HyGridSplitter}">
        <Setter Property="Background" Value="{c:Color BorderSubtle}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HyGridSplitter}">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}">
                        <!-- Grip dots -->
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Vertical">
                            <Ellipse
                                x:Name="Dot1"
                                Width="3" Height="3"
                                Fill="{c:Color TextTertiary}"
                                Margin="0,1" />
                            <Ellipse
                                x:Name="Dot2"
                                Width="3" Height="3"
                                Fill="{c:Color TextTertiary}"
                                Margin="0,1" />
                        </StackPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{c:Color ButtonPrimaryBg}" />
                        </Trigger>

                        <!-- Vertical splitter (ResizeDirection=Columns): narrow width, tall, cursor SizeWE -->
                        <Trigger Property="ResizeDirection" Value="Columns">
                            <Setter Property="Width" Value="{Binding SplitterThickness, RelativeSource={RelativeSource Self}}" />
                            <Setter Property="Cursor" Value="SizeWE" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                        </Trigger>

                        <!-- Horizontal splitter (ResizeDirection=Rows): narrow height, wide, cursor SizeNS -->
                        <Trigger Property="ResizeDirection" Value="Rows">
                            <Setter Property="Height" Value="{Binding SplitterThickness, RelativeSource={RelativeSource Self}}" />
                            <Setter Property="Cursor" Value="SizeNS" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
