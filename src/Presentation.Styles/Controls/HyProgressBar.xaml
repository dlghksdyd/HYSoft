<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:HYSoft.Presentation.Styles.ColorTokens"
    xmlns:local="clr-namespace:HYSoft.Presentation.Styles.Controls">

    <!-- HyProgressBar -->
    <Style TargetType="{x:Type local:HyProgressBar}">
        <Setter Property="Height" Value="6" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="{c:Color ButtonPrimaryBg}" />
        <Setter Property="TrackBackground" Value="{c:Color BorderSubtle}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HyProgressBar}">
                    <Border
                        x:Name="PART_Track"
                        Background="{TemplateBinding TrackBackground}"
                        BorderThickness="0"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Border
                            x:Name="PART_Indicator"
                            HorizontalAlignment="Left"
                            Background="{TemplateBinding Foreground}"
                            CornerRadius="{TemplateBinding CornerRadius}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_Indicator" Property="Width" Value="80" />
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="IndeterminateStoryboard">
                                    <Storyboard RepeatBehavior="Forever">
                                        <ThicknessAnimationUsingKeyFrames
                                            Storyboard.TargetName="PART_Indicator"
                                            Storyboard.TargetProperty="Margin">
                                            <LinearThicknessKeyFrame KeyTime="0:0:0" Value="-80,0,0,0" />
                                            <LinearThicknessKeyFrame KeyTime="0:0:1.5" Value="300,0,0,0" />
                                        </ThicknessAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="IndeterminateStoryboard" />
                            </Trigger.ExitActions>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- HyProgressRing -->
    <Style TargetType="{x:Type local:HyProgressRing}">
        <Setter Property="RingSize" Value="32" />
        <Setter Property="StrokeThickness" Value="3" />
        <Setter Property="RingColor" Value="{c:Color ButtonPrimaryBg}" />
        <Setter Property="IsActive" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HyProgressRing}">
                    <Viewbox
                        Width="{TemplateBinding RingSize}"
                        Height="{TemplateBinding RingSize}">
                        <!-- Grid 32x32: Path 의 geometry bbox (2,2)-(30,30) 와 정확히 매칭.
                             RenderTransformOrigin="0.5,0.5" → (16,16) 으로 회전 중심 고정. -->
                        <Grid Width="32" Height="32" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <RotateTransform x:Name="SpinTransform" Angle="0" />
                            </Grid.RenderTransform>

                            <!-- 270° arc: (16,2) 12시 → 시계방향 large → (2,16) 9시.
                                 12-3-6-9 4 개 cardinal point 통과 → bbox (2,2)-(30,30) 대칭. -->
                            <Path
                                Stroke="{TemplateBinding RingColor}"
                                StrokeThickness="{TemplateBinding StrokeThickness}"
                                StrokeStartLineCap="Round"
                                StrokeEndLineCap="Round">
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="16,2" IsClosed="False">
                                            <ArcSegment
                                                Point="2,16"
                                                Size="14,14"
                                                SweepDirection="Clockwise"
                                                IsLargeArc="True" />
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>
                        </Grid>
                    </Viewbox>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsActive" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="SpinStoryboard">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="SpinTransform"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="SpinStoryboard" />
                            </Trigger.ExitActions>
                        </Trigger>

                        <Trigger Property="IsActive" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
