<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:HYSoft.Presentation.Styles.ColorTokens"
    xmlns:local="clr-namespace:HYSoft.Presentation.Styles.Controls">

    <Style TargetType="{x:Type local:HyPaginator}">
        <Setter Property="Foreground" Value="{c:Color TextPrimary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HyPaginator}">
                    <Border
                        x:Name="Root"
                        Background="{TemplateBinding Background}"
                        SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- First Page -->
                            <Button
                                x:Name="PART_FirstButton"
                                Width="24" Height="24"
                                Padding="4"
                                Cursor="Hand"
                                Focusable="False"
                                Content="&#x23EE;"
                                FontSize="10"
                                Foreground="{TemplateBinding Foreground}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="BtnBorder"
                                            Background="Transparent"
                                            BorderBrush="{c:Color BorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#10000000" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#20000000" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4" />
                                                <Setter Property="Cursor" Value="Arrow" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Previous Page -->
                            <Button
                                x:Name="PART_PreviousButton"
                                Width="24" Height="24"
                                Margin="4,0,0,0"
                                Padding="4"
                                Cursor="Hand"
                                Focusable="False"
                                Content="&#x25C0;"
                                FontSize="8"
                                Foreground="{TemplateBinding Foreground}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="BtnBorder"
                                            Background="Transparent"
                                            BorderBrush="{c:Color BorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#10000000" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#20000000" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4" />
                                                <Setter Property="Cursor" Value="Arrow" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Page Info -->
                            <TextBlock
                                Margin="8,0"
                                VerticalAlignment="Center"
                                FontSize="{TemplateBinding FontSize}"
                                Foreground="{TemplateBinding Foreground}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Page {0} of {1}">
                                        <Binding Path="CurrentPage" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding Path="TotalPages" RelativeSource="{RelativeSource TemplatedParent}" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- Next Page -->
                            <Button
                                x:Name="PART_NextButton"
                                Width="24" Height="24"
                                Padding="4"
                                Cursor="Hand"
                                Focusable="False"
                                Content="&#x25B6;"
                                FontSize="8"
                                Foreground="{TemplateBinding Foreground}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="BtnBorder"
                                            Background="Transparent"
                                            BorderBrush="{c:Color BorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#10000000" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#20000000" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4" />
                                                <Setter Property="Cursor" Value="Arrow" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Last Page -->
                            <Button
                                x:Name="PART_LastButton"
                                Width="24" Height="24"
                                Margin="4,0,0,0"
                                Padding="4"
                                Cursor="Hand"
                                Focusable="False"
                                Content="&#x23ED;"
                                FontSize="10"
                                Foreground="{TemplateBinding Foreground}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="BtnBorder"
                                            Background="Transparent"
                                            BorderBrush="{c:Color BorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#10000000" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#20000000" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4" />
                                                <Setter Property="Cursor" Value="Arrow" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
