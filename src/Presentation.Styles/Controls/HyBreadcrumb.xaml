<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:HYSoft.Presentation.Styles.ColorTokens"
    xmlns:local="clr-namespace:HYSoft.Presentation.Styles.Controls">

    <Style TargetType="{x:Type local:HyBreadcrumbItem}">
        <Setter Property="Foreground" Value="{c:Color TextLink}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HyBreadcrumbItem}">
                    <StackPanel Orientation="Horizontal">
                        <ContentPresenter
                            VerticalAlignment="Center"
                            TextBlock.Foreground="{TemplateBinding Foreground}"
                            TextBlock.FontWeight="{TemplateBinding FontWeight}" />
                        <TextBlock
                            x:Name="SeparatorText"
                            Margin="6,0"
                            VerticalAlignment="Center"
                            Foreground="{c:Color TextSecondary}"
                            Text="{Binding Separator, RelativeSource={RelativeSource AncestorType={x:Type local:HyBreadcrumb}}}" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsLast" Value="True">
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Foreground" Value="{c:Color TextPrimary}" />
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter TargetName="SeparatorText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:HyBreadcrumb}">
        <Setter Property="Foreground" Value="{c:Color TextPrimary}" />
        <Setter Property="Padding" Value="0,4" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HyBreadcrumb}">
                    <Border
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
