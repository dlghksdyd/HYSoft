<Window
    x:Class="TestApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:local="clr-namespace:TestApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TestApp"
    Width="800"
    Height="600"
    WindowStartupLocation="CenterScreen"
    d:DataContext="{d:DesignInstance local:MainWindowViewModel}"
    mc:Ignorable="d">
    <Grid>
        <DockPanel LastChildFill="False" Margin="20">
            <TextBlock
                DockPanel.Dock="Top"
                FontSize="20"
                FontWeight="Bold"
                Margin="0,0,0,20"
                Text="HYSoft TestApp" />

            <Button
                Width="300"
                Padding="10"
                Command="{Binding FileTransferSampleCommand}"
                Content="File Transfer Test"
                DockPanel.Dock="Top" />

            <Separator Height="10" DockPanel.Dock="Top" />

            <Button
                Width="300"
                Padding="10"
                Command="{Binding ModalSampleCommand}"
                Content="Modal Test"
                DockPanel.Dock="Top" />

            <Separator Height="10" DockPanel.Dock="Top" />

            <Button
                Width="300"
                Padding="10"
                Command="{Binding IconSampleCommand}"
                Content="Icon Test"
                DockPanel.Dock="Top" />
        </DockPanel>
    </Grid>
</Window>
