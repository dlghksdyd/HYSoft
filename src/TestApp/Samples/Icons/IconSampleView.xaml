<Window
    x:Class="TestApp.Samples.Icons.IconSampleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hy="http://schemas.hysoft.com/wpf/2025/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Icon Sample"
    Width="800"
    Height="450"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="HyIcon Sample" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <hy:HyIcon Width="48" Height="48" Source="ArrowDropUpFilled" Color="Blue" ColorPressed="Blue" Margin="8" />
                <hy:HyIcon Width="48" Height="48" Source="Save" Color="Black" ColorHover="Green" Margin="8" />
                <hy:HyIcon Width="48" Height="48" Source="Delete" Color="Red" ColorHover="DarkRed" Margin="8" />
                <hy:HyIcon Width="48" Height="48" Source="Settings" Color="Gray" ColorHover="Black" Margin="8" />
                <hy:HyIcon Width="48" Height="48" Source="Home" Color="CornflowerBlue" ColorHover="Blue" Margin="8" />
                <hy:HyIcon Width="48" Height="48" Source="Search" Color="DarkGreen" ColorHover="Green" Margin="8" />
            </StackPanel>
            <TextBlock Text="Hover and click the icons to see tinting" FontSize="12" Foreground="Gray" Margin="0,16,0,0" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
