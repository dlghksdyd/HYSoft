<Window
    x:Class="TestApp.Samples.FileTransfer.FileTransferClientView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TestApp.Samples.FileTransfer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="파일 전송 클라이언트"
    Width="500" Height="200"
    WindowStartupLocation="CenterScreen"
    d:DataContext="{d:DesignInstance local:FileTransferClientViewModel}"
    mc:Ignorable="d">
    <StackPanel Margin="20">
        <StackPanel Orientation="Horizontal">
            <Button Width="120" Height="30" Margin="0,0,8,0"
                    Command="{Binding ClientStartCommand}" Content="클라이언트 준비" />
            <Button Width="120" Height="30"
                    Command="{Binding ClientSendFileCommand}" Content="데이터 전송" />
        </StackPanel>
        <TextBox Margin="0,16,0,0" Height="40" IsReadOnly="True"
                 Text="{Binding Status, FallbackValue=상태값}" />
    </StackPanel>
</Window>
