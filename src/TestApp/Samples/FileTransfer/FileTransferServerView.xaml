<Window
    x:Class="TestApp.Samples.FileTransfer.FileTransferServerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TestApp.Samples.FileTransfer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="파일 전송 서버"
    Width="500" Height="200"
    WindowStartupLocation="CenterScreen"
    d:DataContext="{d:DesignInstance local:FileTransferServerViewModel}"
    mc:Ignorable="d">
    <StackPanel Margin="20">
        <Button Width="130" Height="30" HorizontalAlignment="Left"
                Command="{Binding ServerStartCommand}" Content="서버 시작" />
        <TextBox Margin="0,16,0,0" Height="40" IsReadOnly="True"
                 Text="{Binding Status, FallbackValue=상태값}" />
    </StackPanel>
</Window>
